---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <header class="hero-header">
    <h1 class="hero-heading">
      I'm Daniel Golden, a UI designer and front-end engineer currently working
      as a Design Engineer at Stripe.
    </h1>

    <section class="hero-description">
      <p>
        <span class="superfluous-description">
          I help build the experiences and interactions that my teammates and I
          have designed.
        </span>
        Previously I was a Lead UX Engineer on the design systems team at New
        Relic where I designed and built tools that helped our designers work
        more efficiently.
        <span class="superfluous-description"
          >I also build living, breathing prototypes which enable research,
          testing, and more effective iteration.</span
        >
      </p>
    </section>
  </header>
  <main>
    <section class="work-examples-container">
      <header class="work-examples-header">
        <h5 class="work-heading">Projects</h5>
      </header>
      <div class="work-examples">
        <article class="work-example volon-preview">
          <h3 class="work-example-heading">
            <a href="https://volon.app">Volón</a>
          </h3>
          <p class="work-example-description">
            A local-first, plain-text, keyboard-focused notes app for taking
            notes at work. A love letter to markdown notes.
          </p>
        </article>
        <article class="work-example one-core-toolbox-preview">
          <h3 class="work-example-heading">
            <a href="https://github.com/newrelic/one-core-toolbox"
              >One Core Toolbox</a
            >
          </h3>
          <p class="work-example-description">
            A Figma plugin for product designers at New Relic that enables more
            efficient usage of the New Relic design system.
          </p>
        </article>
        <article class="work-example prose-linter-preview">
          <h3 class="work-example-heading">
            <a href="https://github.com/newrelic/new-relic-language-linter"
              >Prose linter</a
            >
          </h3>
          <p class="work-example-description">
            A tool for anyone who writes UI copy for New Relic that allows them
            test their copy for adherance to the writing style guide.
          </p>
        </article>
        <article class="work-example in-app-docs-preview">
          <h3 class="work-example-heading">
            <a
              href="https://www.figma.com/proto/KfGv2QtR8tPWwI6zjDxOrQ/In-context-Docs-Presentation?page-id=0%3A1&node-id=1%3A7&viewport=579%2C556%2C0.03&scaling=contain&starting-point-node-id=1%3A7"
              >In-context docs</a
            >
          </h3>
          <p class="work-example-description">
            A New Relic feature that allows you to access and search the
            documentation without leaving the context of the incident at hand.
          </p>
        </article>
      </div>
    </section>

    <ul class="social-media-links">
    <li>
        <a href="/writing" class="social-media-link writing-link">Writing</a>
      </li>
      <li>
        <a
          href="https://www.linkedin.com/in/daniel-golden-25637685/"
          class="social-media-link linkedin-link">LinkedIn</a
        >
      </li>
      <li>
        <a
          href="https://github.com/danielgolden"
          class="social-media-link github-link">GitHub</a
        >
      </li>
      <li>
        <a
          href="https://twitter.com/DanGolden1"
          class="social-media-link twitter-link">Twitter</a
        >
      </li>
    </ul>
  </main>
</BaseLayout>
