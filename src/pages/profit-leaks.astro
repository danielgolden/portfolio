---
import Analytics from "@vercel/analytics/astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Profit Leak Audits — Daniel Golden</title>
    <meta
      name="description"
      content="I audit your website and identify the specific profit leaks costing you leads and sales every week — then show you exactly what to fix."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <Analytics />
  </head>
  <body>
    <!-- NAV -->
    <nav>
      <a href="#" class="nav-logo">profit<span>leaks</span></a>
      <a href="#cta" class="nav-cta">Book a free audit call</a>
    </nav>

    <!-- HERO -->
    <section id="hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-tag">For local service & ecommerce businesses</div>
          <h1>Your website is<br /><em>leaking money</em>.<br />I'll find exactly where.</h1>
          <p class="hero-sub">
            I audit your website and identify the specific profit leaks costing you leads and sales
            every week — then show you exactly what to fix.
          </p>
          <div class="hero-actions">
            <a href="#cta" class="btn-primary">Get a free audit call</a>
            <a href="#what" class="btn-ghost">See how it works ↓</a>
          </div>
        </div>
      </div>
    </section>

    <!-- STATS BAR -->
    <div class="stats-bar">
      <div class="stats-inner">
        <div class="stat">
          <span class="stat-num">60%+</span>
          <span class="stat-label">of service business traffic comes from mobile</span>
        </div>
        <div class="stat">
          <span class="stat-num">53%</span>
          <span class="stat-label">of visitors leave if a page loads in 3+ seconds</span>
        </div>
        <div class="stat">
          <span class="stat-num">3×</span>
          <span class="stat-label">more leads from sites with reviews on the homepage</span>
        </div>
        <div class="stat">
          <span class="stat-num">40%</span>
          <span class="stat-label">of form leads lost to unnecessary extra fields</span>
        </div>
      </div>
    </div>

    <!-- WHAT -->
    <section id="what">
      <div class="container">
        <span class="section-label">What is a profit leak audit</span>
        <h2>The specific things costing you leads right now</h2>
        <div class="what-grid">
          <div class="what-left">
            <p>
              Most service business websites have the same problems. Visitors land, look around, and
              leave — without calling, without filling out a form, without buying.
            </p>
            <p>
              A profit leak audit identifies the exact friction points on your site that are causing
              that drop-off, and delivers a prioritized fix list with clear reasoning for each one.
            </p>
            <p>You decide what to do with it: fix them yourself, hire someone else, or hire me.</p>
          </div>
          <div class="leak-list">
            <div class="leak-item">
              <span class="leak-num">1</span>
              <div class="leak-text">
                <strong>No phone number on mobile after scroll</strong>
                <span>Visitors who scroll past your header have no way to call — they leave.</span>
              </div>
            </div>
            <div class="leak-item">
              <span class="leak-num">2</span>
              <div class="leak-text">
                <strong>No reviews or ratings on the homepage</strong>
                <span>Social proof is the #1 conversion driver. Hiding it costs you.</span>
              </div>
            </div>
            <div class="leak-item">
              <span class="leak-num">3</span>
              <div class="leak-text">
                <strong>Contact form with too many fields</strong>
                <span>Each extra field costs you a percentage of completions.</span>
              </div>
            </div>
            <div class="leak-item">
              <span class="leak-num">4</span>
              <div class="leak-text">
                <strong>No real photos of your work</strong>
                <span>Stock photos and generic images destroy trust. Real work converts.</span>
              </div>
            </div>
            <div class="leak-item">
              <span class="leak-num">5</span>
              <div class="leak-text">
                <strong>Competing CTAs with no clear priority</strong>
                <span>When everything is equally important, nothing gets clicked.</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW -->
    <section id="how">
      <div class="container">
        <span class="section-label">How it works</span>
        <h2>Simple process, clear deliverable</h2>
        <div class="steps">
          <div class="step">
            <span class="step-n">01</span>
            <h3>Free audit call</h3>
            <p>
              We spend 20 minutes on the phone. You tell me about your business and what's working
              or not. I look at your site with you.
            </p>
            <span class="step-tag">Free</span>
          </div>
          <div class="step">
            <span class="step-n">02</span>
            <h3>Full site audit</h3>
            <p>
              I inspect your website against proven lead generation best practices — desktop, mobile,
              forms, trust signals, CTAs, and speed.
            </p>
          </div>
          <div class="step">
            <span class="step-n">03</span>
            <h3>Profit leak report</h3>
            <p>
              You get a clear report: what's leaking, why it's costing you, and exactly what to fix
              — prioritized by impact.
            </p>
          </div>
          <div class="step">
            <span class="step-n">04</span>
            <h3>You decide</h3>
            <p>
              Fix them yourself, hire someone else, or hire me to implement the fixes. No pressure,
              no lock-in.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO -->
    <section id="who">
      <div class="container">
        <span class="section-label">Who this is for</span>
        <h2>Built for two types of businesses</h2>
        <div class="who-grid">
          <div class="who-card">
            <h3>Local service businesses</h3>
            <ul>
              <li>HVAC, plumbing, electrical, roofing</li>
              <li>Contractors and remodelers</li>
              <li>Landscaping and outdoor services</li>
              <li>Windows, doors, and exterior work</li>
              <li>Any business where the website's job is to generate calls and form leads</li>
            </ul>
          </div>
          <div class="who-card">
            <h3>Ecommerce businesses</h3>
            <ul>
              <li>Direct-to-consumer product brands</li>
              <li>Specialty retailers with a Shopify or custom store</li>
              <li>Businesses with an email list to grow</li>
              <li>Any store where cart abandonment and conversion rate are the main levers</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- STRIPE STRIP -->
    <div class="stripe-strip">
      <div class="stripe-inner">
        <p>
          Daniel Golden is a <strong>design engineer at Stripe</strong> — the payment infrastructure
          used by Amazon, Google, and millions of businesses worldwide. Profit leak audits are his
          side practice, focused on local and independent businesses.
        </p>
        <a
          href="https://www.linkedin.com/in/daniel-golden-25637685/"
          class="btn-ghost"
          target="_blank"
          rel="noopener">LinkedIn →</a
        >
      </div>
    </div>

    <!-- CTA -->
    <section id="cta">
      <div class="container">
        <span class="section-label" style="color: rgba(245,242,236,0.5);">Get started</span>
        <h2>Find out what your site is leaking</h2>
        <p>
          Enter your website and email. I'll review your site and follow up to schedule a free
          20-minute audit call.
        </p>
        <form class="cta-form" id="audit-form">
          <input type="url" id="site-url" placeholder="yourwebsite.com" required />
          <input type="email" id="email" placeholder="your@email.com" required />
          <button type="submit" id="submit-btn">Find my profit leaks</button>
        </form>
        <p class="cta-note">
          No pitch. No obligation. You walk away with a clear picture of what to fix.
        </p>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <span class="footer-name">profit<span>leaks</span> · Daniel Golden</span>
      <p>Harrisburg, PA · (717) 307-1191</p>
    </footer>

    <script>
      document.getElementById("audit-form")?.addEventListener("submit", (e) => {
        e.preventDefault();
        const btn = document.getElementById("submit-btn") as HTMLButtonElement;
        const urlInput = document.getElementById("site-url") as HTMLInputElement;
        const emailInput = document.getElementById("email") as HTMLInputElement;
        btn.textContent = "Got it — I'll be in touch shortly.";
        btn.disabled = true;
        btn.style.background = "#0F6E56";
        urlInput.disabled = true;
        emailInput.disabled = true;
      });
    </script>
  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ink:       #0F1A12;
    --ink-2:     #3A4A3D;
    --ink-3:     #6B7B6E;
    --surface:   #F5F2EC;
    --surface-2: #EDE9E1;
    --accent:    #1D5C34;
    --accent-2:  #2E7D48;
    --accent-lt: #D4EAD8;
    --border:    rgba(15,26,18,0.12);
    --serif:     'DM Serif Display', Georgia, serif;
    --sans:      'DM Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--sans);
    background: var(--surface);
    color: var(--ink);
    font-size: 17px;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }

  /* NAV */
  nav {
    position: sticky; top: 0; z-index: 100;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 clamp(1.5rem, 5vw, 5rem);
    display: flex; align-items: center; justify-content: space-between;
    height: 62px;
  }
  .nav-logo {
    font-family: var(--serif);
    font-size: 1.1rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }
  .nav-logo span { color: var(--accent); }
  .nav-cta {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
  }
  .nav-cta:hover { background: var(--accent-2); }

  /* SECTIONS */
  section { padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 5rem); }
  .container { max-width: 1060px; margin: 0 auto; }

  /* HERO */
  #hero {
    min-height: calc(100vh - 62px);
    display: flex; align-items: center;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  #hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at 70% 50%, rgba(29,92,52,0.06) 0%, transparent 60%),
      repeating-linear-gradient(0deg, transparent, transparent 39px, var(--border) 39px, var(--border) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, var(--border) 39px, var(--border) 40px);
    pointer-events: none;
  }
  .hero-inner {
    position: relative; z-index: 1;
    max-width: 760px;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: var(--accent-lt);
    color: var(--accent);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    margin-bottom: 2rem;
  }
  .hero-tag::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    display: block;
  }
  h1 {
    font-family: var(--serif);
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }
  h1 em {
    font-style: italic;
    color: var(--accent);
  }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--ink-2);
    max-width: 520px;
    margin-bottom: 2.5rem;
    font-weight: 300;
    line-height: 1.6;
  }
  .hero-actions { display: flex; flex-wrap: wrap; gap: 1rem; align-items: center; }
  .btn-primary {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    font-family: var(--sans);
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--accent-2); transform: translateY(-1px); }
  .btn-ghost {
    color: var(--ink-2);
    font-size: 0.95rem;
    font-weight: 400;
    text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.4rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2px;
    transition: color 0.15s, border-color 0.15s;
  }
  .btn-ghost:hover { color: var(--accent); border-color: var(--accent); }

  /* STATS BAR */
  .stats-bar {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
    padding: 0 clamp(1.5rem, 5vw, 5rem);
  }
  .stats-inner {
    max-width: 1060px; margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0;
  }
  .stat {
    padding: 2rem 1.5rem;
    border-right: 1px solid var(--border);
  }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: var(--serif);
    font-size: 2.5rem;
    color: var(--accent);
    display: block;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .stat-label {
    font-size: 0.875rem;
    color: var(--ink-3);
    font-weight: 400;
  }

  /* WHAT */
  #what { background: var(--surface); }
  .section-label {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
    display: block;
  }
  h2 {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .what-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    margin-top: 3rem;
  }
  @media (max-width: 680px) { .what-grid { grid-template-columns: 1fr; } }
  .what-left p {
    color: var(--ink-2);
    font-size: 1.05rem;
    margin-bottom: 1rem;
    font-weight: 300;
  }

  /* LEAK LIST */
  .leak-list { display: flex; flex-direction: column; gap: 1px; }
  .leak-item {
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 1.25rem 1.5rem;
    display: flex; gap: 1.25rem; align-items: flex-start;
    transition: background 0.15s;
  }
  .leak-item:first-child { border-radius: 6px 6px 0 0; }
  .leak-item:last-child { border-radius: 0 0 6px 6px; }
  .leak-item:hover { background: var(--accent-lt); }
  .leak-num {
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--accent);
    line-height: 1;
    min-width: 1.5rem;
    margin-top: 2px;
  }
  .leak-text strong {
    display: block;
    font-weight: 500;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
    color: var(--ink);
  }
  .leak-text span {
    font-size: 0.875rem;
    color: var(--ink-3);
  }

  /* HOW */
  #how { background: var(--surface-2); border-top: 1px solid var(--border); }
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2px;
    margin-top: 3rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }
  .step {
    background: var(--surface);
    padding: 2rem 1.5rem;
    position: relative;
  }
  .step-n {
    font-family: var(--serif);
    font-size: 3rem;
    color: var(--border);
    line-height: 1;
    margin-bottom: 1rem;
    display: block;
  }
  .step h3 {
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }
  .step p {
    font-size: 0.875rem;
    color: var(--ink-3);
    line-height: 1.55;
    font-weight: 300;
  }
  .step-tag {
    position: absolute; top: 1.25rem; right: 1.25rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-lt);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  /* WHO */
  #who { background: var(--surface); border-top: 1px solid var(--border); }
  .who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }
  @media (max-width: 580px) { .who-grid { grid-template-columns: 1fr; } }
  .who-card {
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.75rem;
  }
  .who-card h3 {
    font-family: var(--sans);
    font-weight: 500;
    font-size: 1rem;
    margin-bottom: 0.75rem;
    color: var(--ink);
  }
  .who-card ul {
    list-style: none;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .who-card li {
    font-size: 0.875rem;
    color: var(--ink-3);
    font-weight: 300;
    display: flex; align-items: center; gap: 0.5rem;
  }
  .who-card li::before {
    content: '→';
    color: var(--accent);
    font-size: 0.8rem;
    flex-shrink: 0;
  }

  /* CTA SECTION */
  #cta {
    background: var(--ink);
    border-top: 1px solid var(--border);
  }
  #cta h2 { color: var(--surface); }
  #cta p {
    color: rgba(245,242,236,0.6);
    font-size: 1.05rem;
    font-weight: 300;
    max-width: 500px;
    margin-bottom: 2.5rem;
  }
  .cta-form {
    display: flex; flex-wrap: wrap; gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .cta-form input {
    flex: 1; min-width: 220px;
    background: rgba(245,242,236,0.08);
    border: 1px solid rgba(245,242,236,0.2);
    border-radius: 4px;
    padding: 0.85rem 1rem;
    font-family: var(--sans);
    font-size: 0.95rem;
    color: var(--surface);
    outline: none;
    transition: border-color 0.15s;
  }
  .cta-form input::placeholder { color: rgba(245,242,236,0.35); }
  .cta-form input:focus { border-color: var(--accent-2); }
  .cta-form button {
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 4px;
    padding: 0.85rem 1.75rem;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }
  .cta-form button:hover { background: var(--accent-2); }
  .cta-note {
    font-size: 0.8rem;
    color: rgba(245,242,236,0.35);
  }

  /* STRIPE STRIP */
  .stripe-strip {
    background: var(--surface-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 1.25rem clamp(1.5rem, 5vw, 5rem);
  }
  .stripe-inner {
    max-width: 1060px; margin: 0 auto;
    display: flex; flex-wrap: wrap; gap: 1rem;
    align-items: center; justify-content: space-between;
  }
  .stripe-inner p {
    font-size: 0.875rem;
    color: var(--ink-3);
    font-weight: 300;
  }
  .stripe-inner strong { color: var(--ink); font-weight: 500; }

  /* FOOTER */
  footer {
    padding: 2rem clamp(1.5rem, 5vw, 5rem);
    border-top: 1px solid var(--border);
    display: flex; flex-wrap: wrap;
    gap: 1rem; align-items: center; justify-content: space-between;
  }
  .footer-name {
    font-family: var(--serif);
    font-size: 1rem;
    color: var(--ink-2);
  }
  .footer-name span { color: var(--accent); }
  footer p {
    font-size: 0.8rem;
    color: var(--ink-3);
  }

  @media (max-width: 480px) {
    .stat { border-right: none; border-bottom: 1px solid var(--border); }
    .stat:last-child { border-bottom: none; }
  }
</style>
