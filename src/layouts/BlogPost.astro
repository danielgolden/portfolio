---
import BaseLayout from "./BaseLayout.astro";
import "../styles/post.css";

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Daniel Golden`} description={description}>
  <main class="post-container">
    <header class="post-header">
      <a href="/writing" class="post-back-link">← Writing</a>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <span class="post-byline">Daniel Golden</span>
        <time class="post-date" datetime={date.toISOString()}>{formattedDate}</time>
      </div>
    </header>
    <article class="post-body">
      <slot />
    </article>
  </main>
</BaseLayout>
